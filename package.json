{
  "name": "@fifthrevision/axle",
  "version": "0.11.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johncch/axle.git"
  },
  "description": "axle is a command line tool for running workflows against LLM APIs.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./models": {
      "types": "./dist/providers/models.d.ts",
      "import": "./dist/providers/models.js"
    }
  },
  "bin": {
    "axle": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "pnpm run build",
    "start": "tsx ./src/cli.ts",
    "build": "tsdown --clean --minify",
    "build:watch": "tsdown --watch",
    "build-dev": "tsdown",
    "test": "vitest run",
    "changelog": "pnpm start -j ./jobs/changelog.job.yml --args",
    "update-models": "pnpm start -j ./jobs/bootstrap-models.job.yml",
    "release": "pnpm test && pnpm run build && npm version"
  },
  "author": "Chong Han Chua",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "marked": "^18.0.2",
    "mime": "^4.1.0",
    "openai": "^6.34.0",
    "serialize-error": "^13.0.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "dotenv": "^17.4.2",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
