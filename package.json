{
  "name": "axle-workspace",
  "version": "0.22.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.5",
  "scripts": {
    "prepare": "pnpm run build",
    "start": "pnpm --filter @fifthrevision/axle build-dev && pnpm exec tsx packages/axle-cli/src/cli.ts",
    "build": "pnpm -r --filter @fifthrevision/axle --filter @fifthrevision/axle-cli build",
    "build:watch": "pnpm --filter @fifthrevision/axle build:watch",
    "build-dev": "pnpm -r --filter @fifthrevision/axle --filter @fifthrevision/axle-cli build-dev",
    "test": "vitest run",
    "changelog": "pnpm start -j ./jobs/changelog.job.yml --args",
    "update-models": "pnpm start -j ./jobs/bootstrap-models.job.yml",
    "release": "node scripts/release.mjs",
    "cut-release": "node scripts/cut-release.mjs",
    "smoke-test": "pnpm exec tsx checks/baseline/run.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@fifthrevision/axle": "workspace:*",
    "@google/genai": "^2.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "publint": "^0.3.21",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  }
}
