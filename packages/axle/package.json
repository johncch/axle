  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@google/genai": "^2.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "marked": "^18.0.4",
    "mime": "^4.1.0",
    "openai": "^6.39.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "publint": "^0.3.21",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
